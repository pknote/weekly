---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 - Page Not Found">
  <div class="min-h-screen flex flex-col items-center justify-center text-center px-4 py-16">
    <h1 class="text-8xl font-bold text-gray-800 dark:text-gray-200 mb-6">404</h1>
    <h2 class="text-3xl font-semibold text-gray-700 dark:text-gray-300 mb-4">Page Not Found</h2>
    <p class="text-xl text-gray-600 dark:text-gray-400 mb-10">抱歉，您访问的页面不存在。</p>
    <a
      href="/"
      class="inline-block px-8 py-4 bg-blue-600 text-white text-lg rounded-lg hover:bg-blue-700 transition-colors"
    >
      返回首页
    </a>
  </div>
</BaseLayout>