---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header/Header.astro';
---

<BaseLayout title="404 - Page Not Found">
  <Header />
  <main class="max-w-4xl mx-auto px-4 py-20 text-center">
    <h1 class="text-6xl font-bold text-gray-800 dark:text-gray-200 mb-6">404</h1>
    <h2 class="text-2xl font-semibold text-gray-700 dark:text-gray-300 mb-4">页面不存在</h2>
    <p class="text-gray-600 dark:text-gray-400 mb-8">抱歉，您访问的页面不存在或已被删除。</p>
    <a
      href="/"
      class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
    >
      返回首页
    </a>
  </main>
</BaseLayout>