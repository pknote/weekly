{
  "permissions": {
    "allow": [
      "Bash(git init:*)",
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(git tag:*)",
      "Bash(ls src/pages/posts/*.md)",
      "Bash(npm run:*)",
      "Bash(git commit:*)",
      "Bash(grep -E \"^\\\\d.*\\\\.html$\")",
