      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:4321/222.html)",
      "Bash(curl -s -I http://localhost:4321/222.html)",
      "Bash(curl -s \"http://localhost:4321/\")",
      "Bash(node -e ':*)",
      "Bash(pkill -f node)",
      "Bash(node --input-type=module)",
      "Bash(ls:*)"
    ]
  }
}
